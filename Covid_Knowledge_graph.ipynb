   "source": [
    "\n",
    "def build_graph(df, relation=False, repulsion=40, title='COVID-19 Knowledge Graph', label_show=False):\n",
    "    \"\"\"\n",
    "    Builds a knowledge graph visualization.\n",
    "\n",
    "    Args:\n",
    "        df: Pandas DataFrame containing entity and relationship information.\n",
    "        relation: Whether to show relationship strength as link thickness.\n",
    "        repulsion: Repulsion force for node layout.\n",
    "        title: Graph title.\n",
    "        label_show: Whether to show node labels.\n",
    "\n",
    "    Returns:\n",
    "        A pyecharts Graph instance.\n",
    "    \"\"\"\n",
    "    entities = set(df['start_entity']) | set(df['end_entity'])\n",
    "    entity_types = df.groupby('start_entity')['start_entity_type'].first().to_dict()\n",
    "    entity_types.update(df.groupby('end_entity')['end_entity_type'].first().to_dict())\n",
    "\n",
    "    # Define node and link data\n",
    "    nodes = [\n",
    "        {'name': entity, 'symbolSize': max(10, np.log1p(df[df['start_entity'] == entity].shape[0] + df[df['end_entity'] == entity].shape[0]) * 10 // 1), 'category': entity_types[entity]}\n",
    "        for entity in entities\n",
    "    ]\n",
    "\n",
    "    links = [\n",
    "        {'source': row['start_entity'], 'target': row['end_entity'], 'value': row['pred']} if relation else \n",
    "        {'source': row['start_entity'], 'target': row['end_entity']} \n",
    "        for _, row in df.iterrows()\n",
    "    ]\n",
    "\n",
    "    # Create and customize the graph\n",
    "    g = Graph()\n",
    "    g.add('', nodes, links, categories=[\n",
    "        {'name': 'Disease', 'itemStyle': {'normal': {'color': '#FF7F50'}}},\n",
    "        {'name': 'Gene', 'itemStyle': {'normal': {'color': '#48D1CC'}}},\n",
    "        {'name': 'Chemical', 'itemStyle': {'normal': {'color': '#B3EE3A'}}}  \n",
    "    ], repulsion=repulsion, label_opts=opts.LabelOpts(is_show=label_show))\n",
    "    g.set_global_opts(title_opts=opts.TitleOpts(title=title), legend_opts=opts.LegendOpts(orient='vertical', pos_left='2%', pos_top='40%', legend_icon='circle')) \n",
    "    with tempfile.NamedTemporaryFile(delete=False, suffix='.html') as tmp_file:\n",
    "        graph_html_path = tmp_file.name\n",
    "    g.render(graph_html_path)\n",
    "\n",
    "    # Use Selenium to take a screenshot\n",
    "    driver = webdriver.Chrome()  # Ensure you have the ChromeDriver installed\n",
    "    driver.get(f\"file://{graph_html_path}\")\n",
    "    screenshot_path = graph_html_path.replace(\".html\", \".png\")\n",
    "    driver.save_screenshot(screenshot_path)\n",
    "    driver.quit()\n",
    "\n",
    "    # Load the screenshot as an OpenCV image\n",
    "    image = cv2.imread(screenshot_path)\n",
    "\n",
    "    # Check if the image was loaded successfully\n",
    "    if image is None:\n",
    "        raise ValueError(\"Failed to load the screenshot. Ensure the file path is correct and valid.\")\n",
    "\n",
    "    # Cleanup temporary files\n",
    "    os.remove(graph_html_path)\n",
    "    os.remove(screenshot_path)\n",
    "    return image"
   ]
  },
