    "import pandas as pd\n",
    "import numpy as np\n",
    "from pyecharts import options as opts\n",
    "from pyecharts.charts import Graph\n",
    "from playwright.sync_api import sync_playwright\n",
    "\n",
    "# DataFrame for demonstration\n",
    "df = pd.DataFrame({\n",
    "    \"start_entity\": [\"COVID-19\", \"COVID-19\", \"Aspirin\"],\n",
    "    \"start_entity_type\": [\"Disease\", \"Disease\", \"Chemical\"],\n",
    "    \"end_entity\": [\"ACE2\", \"TMPRSS2\", \"COVID-19\"],\n",
    "    \"end_entity_type\": [\"Gene\", \"Gene\", \"Disease\"],\n",
    "    \"pred\": [0.8, 0.7, 0.5]\n",
    "})\n",
    "\n",
    "# Function to build the graph\n",
    "def build_graph(df, relation=False, repulsion=1200, title=\"Enhanced Knowledge Graph\", label_show=True):\n",
    "    entities = set(df['start_entity']) | set(df['end_entity'])\n",
    "    entity_types = df.groupby('start_entity')['start_entity_type'].first().to_dict()\n",
    "    entity_types.update(df.groupby('end_entity')['end_entity_type'].first().to_dict())\n",
    "\n",
    "    # Define nodes and links\n",
    "    nodes = [\n",
    "        {\n",
    "            'name': entity,\n",
    "            'symbolSize': max(15, np.log1p(df[df['start_entity'] == entity].shape[0] + df[df['end_entity'] == entity].shape[0]) * 10),\n",
    "            'category': entity_types.get(entity, \"Unknown\"),\n",
    "            'label': {\n",
    "                'show': True,\n",
    "                'formatter': entity,\n",
    "                'fontSize': 12,\n",
    "                'color': 'black'\n",
    "            },\n",
    "            'itemStyle': {\n",
    "                'color': '#FF7F50' if entity_types.get(entity) == 'Disease' \n",
    "                else '#48D1CC' if entity_types.get(entity) == 'Gene' \n",
    "                else '#B3EE3A'\n",
    "            },\n",
    "        }\n",
    "        for entity in entities\n",
    "    ]\n",
    "\n",
    "    links = [\n",
    "        {\n",
    "            'source': row['start_entity'], \n",
    "            'target': row['end_entity'], \n",
    "            'value': row['pred'],\n",
    "            'lineStyle': {\n",
    "                'width': 2,\n",
    "                'curveness': 0.3,\n",
    "                'opacity': 0.8\n",
    "            },\n",
    "            'label': {\n",
    "                'show': relation,\n",
    "                'formatter': row['pred'] if relation else \"\",\n",
    "                'color': 'blue',\n",
    "                'fontSize': 10,\n",
    "            }\n",
    "        }\n",
    "        for _, row in df.iterrows()\n",
    "    ]\n",
    "\n",
    "    # Create and customize the graph\n",
    "    g = Graph()\n",
    "    g.add(\n",
    "        \"\",\n",
    "        nodes,\n",
    "        links,\n",
    "        categories=[\n",
    "            {'name': 'Disease', 'itemStyle': {'color': '#FF7F50'}},\n",
    "            {'name': 'Gene', 'itemStyle': {'color': '#48D1CC'}},\n",
    "            {'name': 'Chemical', 'itemStyle': {'color': '#B3EE3A'}}\n",
    "        ],\n",
    "        layout=\"force\",\n",
    "        repulsion=repulsion,\n",
    "        edge_label=opts.LabelOpts(is_show=True, formatter=\"{c}\"),\n",
    "        label_opts=opts.LabelOpts(is_show=label_show, position=\"inside\", font_size=10),\n",
    "    )\n",
    "\n",
    "    # Set global options\n",
    "    g.set_global_opts(\n",
    "        title_opts=opts.TitleOpts(title=title, title_textstyle_opts=opts.TextStyleOpts(font_size=16)),\n",
