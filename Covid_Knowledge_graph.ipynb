    "import pandas as pd\n",
    "from sklearn.model_selection import train_test_split\n",
    "from sklearn.preprocessing import LabelEncoder\n",
    "from sklearn.naive_bayes import MultinomialNB\n",
    "from sklearn.metrics import accuracy_score, classification_report\n",
    "\n",
    "# Load dataset from a CSV file\n",
    "df = pd.read_csv(r\"C:\\Users\\subha\\OneDrive\\Desktop\\marked_sentence.csv\")\n",
    "\n",
    "# Debugging: Check column names and preview the dataset\n",
    "print(\"Columns in the dataset:\", df.columns)\n",
    "print(\"Dataset Preview:\")\n",
    "print(df.head(100))\n",
    "\n",
    "# Ensure the column names match\n",
    "if 'Gene' not in df.columns or 'disease' not in df.columns:\n",
    "    print(\"Error: Expected columns 'disease' and 'medicine' not found in the dataset.\")\n",
    "    # Optional: rename columns if needed\n",
    "    # df.rename(columns={'YourActualDiseaseColumn': 'disease', 'YourActualMedicineColumn': 'medicine'}, inplace=True)\n",
    "\n",
    "# Proceed only if the required columns exist\n",
    "if 'Gene' in df.columns and 'disease' in df.columns:\n",
    "    # Select a range of rows for training (e.g., rows 0 to 4)\n",
    "    start_row = 0\n",
    "    end_row = 5\n",
    "    df = df.iloc[start_row:end_row]\n",
    "\n",
    "    # Preprocessing\n",
    "    le_gene = LabelEncoder()\n",
    "    le_disease = LabelEncoder()\n",
    "\n",
    "    df['gene_encoded'] = le_gene.fit_transform(df['gene'])\n",
    "    df['disease_encoded'] = le_disease.fit_transform(df['disease'])\n",
    "\n",
    "    # Feature and target variables\n",
    "    X = df[['gene_encoded']]\n",
    "    y = df['disease_encoded']\n",
    "\n",
    "    # Train-test split\n",
    "    X_train, X_test, y_train, y_test = train_test_split(X, y, test_size=0.3, random_state=42)\n",
    "\n",
    "    # Build a Naive Bayes model\n",
    "    model = MultinomialNB()\n",
    "    model.fit(X_train, y_train)\n",
    "\n",
    "    # Predictions\n",
    "    y_pred = model.predict(X_test)\n",
    "\n",
    "    # Evaluate the model\n",
    "    print(\"Model Accuracy:\", accuracy_score(y_test, y_pred))\n",
    "    print(\"Classification Report:\\n\", classification_report(y_test, y_pred))\n",
    "\n",
    "    # Inference function to predict medicine based on disease input\n",
    "    def predict_medicine(disease):\n",
    "        try:\n",
    "            disease_encoded = le_disease.transform([disease])[0]\n",
    "            medicine_encoded = model.predict([[disease_encoded]])[0]\n",
    "            medicine = le_medicine.inverse_transform([medicine_encoded])[0]\n",
    "            return medicine\n",
    "        except ValueError:\n",
    "            return \"Disease not found in the training data. Please try a different input.\"\n",
    "\n",
    "    # User input for prediction\n",
    "    input_disease = input(\"Enter the name of a disease to predict its medicine: \")\n",
    "    predicted_medicine = predict_medicine(input_disease)\n",
    "    print(f\"For the disease '{input_disease}', the predicted medicine is: {predicted_medicine}\")\n",
    "else:\n",
    "    print(\"Cannot proceed without the required columns.\")"
   ]
  },
