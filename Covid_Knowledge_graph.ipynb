   "source": [
    "import pandas as pd\n",
    "import numpy as np\n",
    "from sklearn.model_selection import train_test_split\n",
    "from sklearn.preprocessing import LabelEncoder\n",
    "from sklearn.naive_bayes import MultinomialNB\n",
    "from sklearn.metrics import accuracy_score, classification_report\n",
    "from pyecharts import options as opts\n",
    "from pyecharts.charts import Graph\n",
    "import webbrowser\n",
    "\n",
    "# Load dataset from a CSV file\n",
    "df = pd.read_csv(r\"C:\\Users\\subha\\OneDrive\\Desktop\\marked_sentence.csv\")\n",
    "\n",
    "# Debugging: Check column names and preview the dataset\n",
    "print(\"Columns in the dataset:\", df.columns)\n",
    "print(\"Dataset Preview:\")\n",
    "print(df.head(100))\n",
    "\n",
    "# Ensure the column names match\n",
    "if 'start_entity' not in df.columns or 'end_entity' not in df.columns:\n",
    "    print(\"Error: Expected columns 'start_entity' and 'end_entity' not found in the dataset.\")\n",
    "else:\n",
    "    # Filter rows where 'start_entity_type' is 'Gene' and 'end_entity_type' is 'Disease'\n",
    "    df = df[(df['start_entity_type'] == 'Gene') & (df['end_entity_type'] == 'Disease')]\n",
    "\n",
    "    # Rename columns for clarity\n",
    "    df.rename(columns={'start_entity': 'gene', 'end_entity': 'disease'}, inplace=True)\n",
    "\n",
    "    # Debugging: Verify the filtered dataset\n",
    "    print(\"Filtered Dataset Preview:\")\n",
    "    print(df.head())\n",
    "\n",
    "    # Preprocessing\n",
    "    le_gene = LabelEncoder()\n",
    "    le_disease = LabelEncoder()\n",
    "\n",
    "    df['gene_encoded'] = le_gene.fit_transform(df['gene'])\n",
    "    df['disease_encoded'] = le_disease.fit_transform(df['disease'])\n",
    "\n",
    "    # Feature and target variables\n",
    "    X = df[['gene_encoded']]\n",
    "    y = df['disease_encoded']\n",
    "\n",
    "    # Train-test split\n",
    "    X_train, X_test, y_train, y_test = train_test_split(X, y, test_size=0.3, random_state=42)\n",
    "\n",
    "    # Build a Naive Bayes model\n",
    "    model = MultinomialNB()\n",
    "    model.fit(X_train, y_train)\n",
    "\n",
    "    # Predictions\n",
    "    y_pred = model.predict(X_test)\n",
    "\n",
    "    # Evaluate the model\n",
    "    print(\"Model Accuracy: \", accuracy_score(y_test, y_pred))\n",
    "    print(\"Classification Report:\\n\", classification_report(y_test, y_pred))\n",
    "\n",
    "    # Debugging: Print the classes seen during training\n",
    "    print(\"Genes in the training dataset:\", le_gene.classes_)\n",
    "\n",
    "    # Inference function to predict disease based on gene input\n",
    "    def predict_disease(gene):\n",
    "        if gene not in le_gene.classes_:\n",
    "            return \"Gene not found in the training data. Please try a different input.\"\n",
    "        gene_encoded = le_gene.transform([gene])[0]\n",
    "        disease_encoded = model.predict([[gene_encoded]])[0]\n",
    "        disease = le_disease.inverse_transform([disease_encoded])[0]\n",
    "        return disease\n",
    "\n",
    "    # User input for prediction\n",
    "    input_gene = input(\"Enter the name of a gene to predict its associated disease: \")\n",
    "    predicted_disease = predict_disease(input_gene)\n",
    "    print(f\"For the gene '{input_gene}', the predicted disease is: {predicted_disease}\")\n",
    "\n",
    "    # Check if the prediction is correct\n",
    "    is_correct = \"Yes\" if predicted_disease in df[df['gene'] == input_gene]['disease'].values else \"No\"\n",
    "    print(f\"Prediction correct: {is_correct}\")\n",
    "\n",
    "    # Add the prediction status to the DataFrame\n",
    "    df['prediction_status'] = df.apply(\n",
    "        lambda row: \"Correct\" if le_disease.inverse_transform([model.predict([[le_gene.transform([row['gene']])[0]]])[0]]) == row['disease']\n",
    "        else \"Incorrect\", axis=1\n",
    "    )\n",
    "\n",
    "# Check if the required columns exist in the dataset\n",
    "required_columns = [\"start_entity\", \"start_entity_type\", \"end_entity\", \"end_entity_type\", \"pred\"]\n",
    "missing_columns = [col for col in required_columns if col not in df.columns]\n",
    "\n",
    "if missing_columns:\n",
    "    print(f\"Warning: The following required columns are missing: {missing_columns}\")\n",
    "    print(f\"Available columns in the dataset: {df.columns.tolist()}\")\n",
    "    for col in missing_columns:\n",
    "        df[col] = pd.NA  # Fill missing columns with NaN\n",
    "else:\n",
    "    print(\"All required columns are present.\")\n",
    "\n",
    "# Limit the DataFrame to the first 1000 rows\n",
    "marked_sentence_df = df.head(1000)\n",
    "\n",
    "# Build the graph\n",
    "def build_graph(df, relation=False, repulsion=1200, title=\"Enhanced Knowledge Graph\", label_show=True):\n",
    "    entities = set(df['gene']) | set(df['disease'])\n",
    "    entity_types = df.groupby('gene')['start_entity_type'].first().to_dict()\n",
    "    entity_types.update(df.groupby('disease')['end_entity_type'].first().to_dict())\n",
    "\n",
    "    # Define node and link data\n",
    "    nodes = [\n",
    "        {\n",
    "            'name': entity,\n",
    "            'symbolSize': max(15, np.log1p(df[df['gene'] == entity].shape[0] + df[df['disease'] == entity].shape[0]) * 10),\n",
    "            'category': entity_types.get(entity, \"Unknown\"),\n",
    "            'label': {\n",
    "                'show': True,\n",
    "                'formatter': entity,\n",
    "                'fontSize': 12,\n",
    "                'color': 'black'\n",
    "            },\n",
    "            'itemStyle': {\n",
    "                'color': '#FF7F50' if entity_types.get(entity) == 'Disease' \n",
    "                else '#48D1CC' if entity_types.get(entity) == 'Gene' \n",
    "                else '#B3EE3A'\n",
    "            },\n",
    "        }\n",
    "        for entity in entities\n",
    "    ]\n",
    "\n",
    "    links = [\n",
    "        {\n",
    "            'source': row['gene'], \n",
    "            'target': row['disease'], \n",
    "            'value': row['pred'],\n",
    "            'lineStyle': {\n",
    "                'width': 2,\n",
    "                'curveness': 0.3,  # Adjust curve for clarity\n",
    "                'opacity': 0.8,\n",
    "                'color': 'green' if row['prediction_status'] == \"Correct\" else 'red'\n",
    "            },\n",
    "            'label': {\n",
    "                'show': relation,\n",
    "                'formatter': row['pred'] if relation else \"\",\n",
    "                'color': 'blue',\n",
    "                'fontSize': 10,\n",
    "            }\n",
    "        }\n",
    "        for _, row in df.iterrows()\n",
    "    ]\n",
    "\n",
    "    # Create and customize the graph\n",
    "    g = Graph()\n",
    "    g.add(\n",
    "        \"\",\n",
    "        nodes,\n",
    "        links,\n",
    "        categories=[ \n",
    "            {'name': 'Disease', 'itemStyle': {'color': '#FF7F50'}},\n",
    "            {'name': 'Gene', 'itemStyle': {'color': '#48D1CC'}},\n",
    "            {'name': 'Chemical', 'itemStyle': {'color': '#B3EE3A'}}\n",
    "        ],\n",
    "        layout=\"force\",  # Force layout for dynamic spacing\n",
    "        repulsion=repulsion,\n",
    "        edge_label=opts.LabelOpts(is_show=True, formatter=\"{c}\"),\n",
    "        label_opts=opts.LabelOpts(is_show=label_show, position=\"inside\", font_size=10),\n",
    "    )\n",
    "\n",
    "    # Set global options for title and legend\n",
    "    g.set_global_opts(\n",
    "        title_opts=opts.TitleOpts(title=title, title_textstyle_opts=opts.TextStyleOpts(font_size=16)),\n",
    "        legend_opts=opts.LegendOpts(\n",
    "            orient='vertical',\n",
    "            pos_left='2%',\n",
    "            pos_top='20%',\n",
    "            textstyle_opts=opts.TextStyleOpts(font_size=12),\n",
    "            legend_icon='circle',\n",
    "        )\n",
    "    )\n",
    "\n",
    "    return g\n",
    "\n",
    "# Build and render the enhanced graph for 1000 items\n",
    "enhanced_graph = build_graph(marked_sentence_df, relation=True, repulsion=1200, title=\"Enhanced Knowledge Graph (1000 Items)\", label_show=True)\n",
    "# Save and open the graph\n",
    "output_file = \"enhanced_knowledge_graph_1000.html\"\n",
    "enhanced_graph.render(output_file)\n",
    "webbrowser.open(output_file)"
   ]
  },
